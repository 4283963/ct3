{
  "name": "dynamic-rbac-gateway",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev:server": "npm --workspace=@rbac/server run dev",
    "dev:client": "npm --workspace=@rbac/client run dev",
    "dev": "concurrently -n server,client -c blue,green \"npm run dev:server\" \"npm run dev:client\"",
    "build:server": "npm --workspace=@rbac/server run build",
    "build:client": "npm --workspace=@rbac/client run build",
    "build": "npm run build:server && npm run build:client"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
